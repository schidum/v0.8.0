# ==================== ENVIRONMENT ====================
# Options: development, staging, production
ENVIRONMENT=development
DEBUG=False

# ==================== DATABASE ====================
DATABASE_URL=sqlite+aiosqlite:///./agro.db

# ==================== JWT CONFIGURATION ====================
# Generate a strong secret key (minimum 32 characters, recommended 64+)
# Linux/Mac: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Windows PowerShell: [Convert]::ToBase64String([System.Security.Cryptography.RNGCryptoServiceProvider]::new().GetBytes(32))
SECRET_KEY=your_super_secret_key_minimum_32_characters_recommended_64_characters

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ==================== RABBITMQ CONFIGURATION ====================
# For local development with default RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# For production, use strong credentials:
# RABBITMQ_URL=amqp://username:password@rabbitmq.example.com:5672//

CELERY_RESULT_BACKEND=rpc://

# ==================== CORS CONFIGURATION ====================
# Development: Allow localhost
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Staging: Add staging domain
# CORS_ORIGINS=http://localhost:8000,https://staging.agro.example.com,https://api-staging.agro.example.com

# Production: Only allow production domains (HTTPS required)
# CORS_ORIGINS=https://agro.example.com,https://api.agro.example.com,https://mobile.agro.example.com

CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600

# ==================== APPLICATION ====================
APP_TITLE=Агро API — Точное земледелие
APP_VERSION=0.8.0
